  "keyFeatures": [
    "Portfolio performance tracking (ROAI, WTD, MTD, YTD, 1Y, 5Y, Max)",
    "Multi-account management across brokerages and exchanges",
    "Transaction import and export (BUY, SELL, DIVIDEND, FEE, INTEREST, ITEM, LIABILITY)",
    "Static portfolio risk analysis and diversification insights",
    "Support for stocks, ETFs, cryptocurrencies, and custom assets",
    "Multiple data providers (Yahoo Finance, CoinGecko, Alpha Vantage, and more)",
    "Dark Mode, Zen Mode, and Progressive Web App (PWA)",
    "Public portfolio sharing with access controls",
    "Self-hosting via Docker with PostgreSQL and Redis",
    "REST API with JWT and API key authentication"
  ],
